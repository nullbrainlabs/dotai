{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash"
    ],
    "deny": [
      "Read(node_modules/)",
      "Edit(node_modules/)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo done"
          }
        ],
        "matcher": "Bash"
      }
    ]
  }
}
