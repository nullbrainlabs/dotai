{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm *)"
    ],
    "deny": [
      "Edit(*.lock)",
      "Read(dist/)",
      "Edit(dist/)",
      "Read(.env*)",
      "Edit(.env*)"
    ],
    "ask": [
      "WebSearch"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'editing file'"
          }
        ],
        "matcher": "Edit"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "prompt",
            "prompt": "Summarize the user request before proceeding."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "agent",
            "prompt": "Review project context and prepare workspace."
          }
        ]
      }
    ]
  }
}
