---
import Navigation from '../components/landing/Navigation.astro';
import HeroSection from '../components/landing/HeroSection.astro';
import ProblemSection from '../components/landing/ProblemSection.astro';
import HowItWorksSection from '../components/landing/HowItWorksSection.astro';
import SupportedToolsSection from '../components/landing/SupportedToolsSection.astro';
import FeaturesSection from '../components/landing/FeaturesSection.astro';
import DevelopersSection from '../components/landing/DevelopersSection.astro';
import CtaSection from '../components/landing/CtaSection.astro';
import FooterSection from '../components/landing/FooterSection.astro';
import '../styles/landing.css';
---
<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>.ai — One config. Every AI tool.</title>
	<meta name="description" content="One config, every AI coding tool. Unified configuration for Claude Code, Cursor, Codex, and GitHub Copilot." />
	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Geist+Mono:wght@400;500;600;700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;600;700&display=swap" rel="stylesheet" />
	<script is:inline>
		(function() {
			var theme = localStorage.getItem('ld-theme');
			if (!theme) theme = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
			document.documentElement.setAttribute('data-theme', theme);
		})();
	</script>
</head>
<body class="landing-page">
	<Navigation />
	<HeroSection />
	<ProblemSection />
	<HowItWorksSection />
	<SupportedToolsSection />
	<FeaturesSection />
	<DevelopersSection />
	<CtaSection />
	<FooterSection />

	<script>
		// Fetch GitHub star count
		(async () => {
			try {
				const cached = sessionStorage.getItem('gh-stars');
				const cachedAt = sessionStorage.getItem('gh-stars-ts');
				let count: string | null = null;

				if (cached && cachedAt && Date.now() - Number(cachedAt) < 300_000) {
					count = cached;
				} else {
					const res = await fetch('https://api.github.com/repos/nullbrainlabs/dotai');
					if (res.ok) {
						const data = await res.json();
						const stars = data.stargazers_count as number;
						count = stars >= 1000 ? `${(stars / 1000).toFixed(1)}k` : String(stars);
						sessionStorage.setItem('gh-stars', count);
						sessionStorage.setItem('gh-stars-ts', String(Date.now()));
					}
				}

				if (count) {
					document.querySelectorAll<HTMLElement>('.ld-star-count, .ld-nav-star-count').forEach(el => {
						el.appendChild(document.createTextNode(count));
						el.style.display = 'inline-flex';
					});
				}
			} catch {}
		})();

		// Scroll reveal observer
		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			},
			{ threshold: 0.1 }
		);

		document.querySelectorAll('.ld-reveal').forEach(el => observer.observe(el));
	</script>
</body>
</html>
