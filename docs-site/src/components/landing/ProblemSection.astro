---
const tools = [
	{
		name: "Claude Code",
		files: ["CLAUDE.md", ".claude/settings.json", ".mcp.json"],
	},
	{
		name: "Cursor",
		files: [".cursor/rules/*.mdc", ".cursor/mcp.json", ".cursorignore"],
	},
	{
		name: "Codex",
		files: ["AGENTS.md", ".codex/config.toml"],
	},
	{
		name: "GitHub Copilot",
		files: [".github/copilot-instructions.md", ".github/agents/*.agent.md", ".vscode/mcp.json"],
	},
];
---
<section class="ld-section ld-problem" id="problem">
	<div class="ld-container">
		<div class="ld-reveal" style="text-align:center;margin-bottom:3rem;">
			<p class="ld-section-label">// The reality</p>
			<h2 class="ld-section-title">Same intent. Different files. Everywhere.</h2>
		</div>
		<div class="ld-problem-grid ld-reveal ld-delay-1">
			{tools.map(t => (
				<div class="ld-problem-col">
					<h3>{t.name}</h3>
					<ul>
						{t.files.map(f => <li>{f}</li>)}
					</ul>
				</div>
			))}
		</div>
		<p class="ld-problem-punchline ld-reveal ld-delay-2">
			They all want the same thing — how to behave in your repo.<br>They just can't agree on where to put it.
		</p>
	</div>
</section>
